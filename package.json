    "pull-request",
    "scout-spirit",
    "boy-scout-rule",
    "refactoring"
  ],
  "license": "Apache-2.0",
  "dependencies": {
    "@octokit/rest": "^21.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "tsx": "^4.7.0",
    "typescript": "^5.3.0"
  },
  "engines": {
    "node": ">=20"
  }
}
