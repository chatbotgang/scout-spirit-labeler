{
  "name": "scout-spirit-labeler",
  "private": true,
  "version": "1.0.0",
  "description": "AI-powered GitHub Action that labels PRs exhibiting Scout Spirit ⚜️ — the Boy Scout Rule of leaving code cleaner than you found it",
